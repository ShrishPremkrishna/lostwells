# Copy this file to `.env` (repo root) and fill in your keys.
# `.env` is gitignored — it will NOT be committed.
# The Python pipeline (swarm / story / case assembly) auto-loads this file via
# services/dotenv_min.py. For the Next.js live route, also copy the same line into
# apps/web/.env.local (Next.js loads that automatically, server-side only).

ANTHROPIC_API_KEY=sk-ant-your-key-here

# Phase 3 (optional, when you have them):
# REDIS_URL=redis://localhost:6379
# BROWSERBASE_API_KEY=
# BROWSERBASE_PROJECT_ID=
# CENSUS_API_KEY=
